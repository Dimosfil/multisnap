{
  "version": 1,
  "project_id": "multisnap",
  "mode": "hybrid-ready",
  "source_groups": [
    {
      "id": "local-instructions",
      "paths": [
        "AGENTS.md",
        "COMMANDS.md",
        "README.md",
        "docs/*.md",
        "patterns/*.md",
        "patterns/AGENTS_RUNTIME/*.md",
        "tools/AGENT_RUNBOOK.md",
        "tools/AGENT_WORKING_AGREEMENTS.md"
      ],
      "trust": "project-local",
      "include": true
    },
    {
      "id": "project-memory",
      "paths": [
        "tools/project-memory/*.md",
        "tools/project-memory/*.json",
        "tools/project-memory/**/*.md",
        "tools/project-memory/**/*.json"
      ],
      "trust": "project-local",
      "include": true
    }
  ],
  "exclude_globs": [
    "**/.env*",
    "**/*secret*",
    "**/*token*",
    "**/node_modules/**",
    "**/dist/**",
    "**/build/**",
    "**/*.log",
    "**/*.lock",
    "tools/project-memory/*.sqlite",
    "tools/project-memory/*.sqlite-*",
    "tools/project-memory/*.db",
    "tools/project-memory/*.db-*",
    "tools/project-memory/embedding-cache/**",
    "tools/project-memory/semantic-corpus*.jsonl",
    "tools/project-memory/vector-index/**"
  ],
  "structured_memory": {
    "kind": "sqlite",
    "path": "tools/project-memory/project_memory.sqlite",
    "commit_database": false,
    "reviewable_export": "tools/project-memory/NOTES.md"
  },
  "keyword_retrieval": {
    "enabled": true,
    "kind": "sqlite-fts5",
    "purpose": "exact paths, commands, symbols, and error text"
  },
  "chunking": {
    "enabled": true,
    "kind": "markdown-aware",
    "max_chars": 4000,
    "export_path": "tools/project-memory/semantic-corpus.jsonl"
  },
  "embedding_metadata": {
    "model_ref": "configure-in-project-local-runtime",
    "provider": "configure-in-project-local-runtime",
    "dimensions": null,
    "collection_version": "multisnap-project-memory-v1",
    "embed_source": "chunks",
    "do_not_mix_models_in_collection": true
  },
  "vector_retrieval": {
    "enabled": false,
    "provider": "chroma",
    "collection": "multisnap-project-memory-v1",
    "local_index_path": "tools/project-memory/vector-index/chroma",
    "embedding_model_ref": "configure-in-project-local-runtime",
    "dimensions": null
  },
  "service_retrieval": {
    "enabled": false,
    "provider": "qdrant",
    "service_id": "",
    "collection": "multisnap-project-memory-v1"
  },
  "context_packet": {
    "max_chunks": 8,
    "max_estimated_tokens": 4000,
    "require_source_paths": true,
    "include_rejected_source_summary": false
  },
  "activation_limits": {
    "structured_memory": {
      "default_enabled": true,
      "max_query_results": 20,
      "small_limit_default": 8,
      "requires_source_verification_before_edit": true
    },
    "vector_retrieval": {
      "default_enabled": false,
      "max_query_results": 12,
      "requires_explicit_enablement": true,
      "requires_embedding_metadata": true,
      "requires_source_verification_before_edit": true
    }
  },
  "rebuild": {
    "full_command": "gi tools rebuild",
    "aliases": [
      "gi rag rebuild"
    ],
    "requires_confirmation": true,
    "last_full_rebuild_migration": "2026.06.16.5",
    "last_full_rebuild_at": "",
    "node_commands": {
      "sql": {
        "command": "python .\\tools\\project-memory\\build_project_memory_index.py rebuild",
        "status_command": "python .\\tools\\project-memory\\build_project_memory_index.py stats"
      },
      "chunks": {
        "command": "python .\\tools\\project-memory\\build_project_memory_index.py export-chunks",
        "status_command": ""
      },
      "vector": {
        "command": "uv run --with chromadb python .\\tools\\project-memory\\build_chroma_index.py rebuild",
        "status_command": "uv run --with chromadb python .\\tools\\project-memory\\build_chroma_index.py stats",
        "enabled": false
      },
      "manifest": {
        "command": "",
        "status_command": "",
        "configured": false
      },
      "evals": {
        "command": "",
        "status_command": "",
        "configured": false
      }
    },
    "last_node_rebuilds": {
      "sql": {
        "last_rebuild_at": "2026-07-04T13:27:06+00:00",
        "last_rebuild_migration": "2026.07.04.1",
        "status": "succeeded"
      },
      "chunks": {
        "last_rebuild_at": "2026-07-04T13:27:06+00:00",
        "last_rebuild_migration": "2026.07.04.1",
        "status": "succeeded"
      }
    }
  },
  "writeback": {
    "write_verified_findings": true,
    "markdown_export": "tools/project-memory/NOTES.md",
    "store_uncertain_findings": "mark-explicitly"
  }
}
