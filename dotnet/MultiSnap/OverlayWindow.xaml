<Window x:Class="MultiSnap.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None" ResizeMode="NoResize" AllowsTransparency="True"
        Background="Transparent" Topmost="True" ShowInTaskbar="False"
        Cursor="Cross" WindowStartupLocation="Manual">
    <Grid MouseLeftButtonDown="Overlay_MouseLeftButtonDown"
          MouseMove="Overlay_MouseMove"
          MouseLeftButtonUp="Overlay_MouseLeftButtonUp"
          KeyDown="Overlay_KeyDown">
        <Image x:Name="ScreenshotImage" Stretch="Fill" />
        <Rectangle Fill="#44000000" />
        <Canvas x:Name="SelectionCanvas" Background="Transparent">
            <Rectangle x:Name="SelectionRect" Stroke="#ef1f2d" StrokeThickness="2"
                       Fill="#22ef1f2d" Visibility="Collapsed" />
        </Canvas>
    </Grid>
</Window>
