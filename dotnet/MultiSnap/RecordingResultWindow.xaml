<Window x:Class="MultiSnap.RecordingResultWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Recording Result" Height="520" Width="760" MinHeight="430" MinWidth="620"
        Background="{StaticResource AppBackgroundBrush}" WindowStartupLocation="CenterOwner">
    <Grid Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Margin="0,0,0,18">
            <Image Source="{StaticResource AppIconImage}" Width="42" Height="42" Margin="0,0,12,0" />
            <StackPanel>
                <TextBlock Text="Recording Result" Foreground="{StaticResource TextPrimaryBrush}"
                           FontSize="24" FontWeight="SemiBold" />
                <TextBlock x:Name="ResultStatusText" Text="Preparing video..."
                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,4,0,0" />
            </StackPanel>
        </StackPanel>

        <Border Grid.Row="1" Background="{StaticResource SurfaceBackgroundBrush}"
                BorderBrush="{StaticResource StrokeBrush}" BorderThickness="1" CornerRadius="8"
                ClipToBounds="True">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <MediaElement x:Name="PreviewPlayer" Grid.Row="0" LoadedBehavior="Manual" UnloadedBehavior="Stop"
                              Stretch="Uniform" MediaOpened="PreviewPlayer_MediaOpened"
                              MediaEnded="PreviewPlayer_MediaEnded" />
                <StackPanel x:Name="EmptyPreview" Grid.Row="0" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="Video preview will appear here" Foreground="{StaticResource TextPrimaryBrush}"
                               FontSize="22" FontWeight="SemiBold" HorizontalAlignment="Center" />
                    <TextBlock x:Name="EmptyPreviewDetails"
                               Text="The recording UI is ready; the encoder pipeline has not produced a file yet."
                               Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap"
                               Width="430" TextAlignment="Center" Margin="0,8,0,0" />
                </StackPanel>

                <Grid x:Name="PlayerControls" Grid.Row="1" Visibility="Collapsed"
                      Background="{StaticResource AppBackgroundBrush}" MinHeight="52" Margin="0,1,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0,10,0">
                        <Button x:Name="PlayPauseButton" Content="Pause" Width="72" Height="30" Margin="0,0,8,0"
                                Click="PlayPause_Click" />
                        <Button Content="Stop" Width="64" Height="30" Click="StopPlayback_Click" />
                    </StackPanel>
                    <Slider x:Name="TimelineSlider" Grid.Column="1" Minimum="0" Maximum="1"
                            VerticalAlignment="Center" ValueChanged="TimelineSlider_ValueChanged" />
                    <TextBlock x:Name="TimeText" Grid.Column="2" Text="00:00 / 00:00"
                               Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"
                               Margin="12,0,14,0" MinWidth="96" TextAlignment="Right" />
                </Grid>
            </Grid>
        </Border>

        <Grid Grid.Row="2" Margin="0,18,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="120" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock x:Name="FilePathText" Grid.Column="0" Foreground="{StaticResource TextSecondaryBrush}"
                       VerticalAlignment="Center" TextTrimming="CharacterEllipsis" Margin="0,0,14,0" />
            <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="SaveAsButton" Content="Save As" Width="88" Height="34" Margin="0,0,8,0"
                        Click="SaveAs_Click" />
                <Button x:Name="CopyPathButton" Content="Copy Path" Width="92" Height="34" Margin="0,0,8,0"
                        Click="CopyPath_Click" />
                <Button x:Name="OpenFolderButton" Content="Open Folder" Width="102" Height="34" Margin="0,0,8,0"
                        Click="OpenFolder_Click" />
                <Button x:Name="DeleteButton" Content="Delete" Width="78" Height="34" Margin="0,0,8,0"
                        Click="Delete_Click" />
                <Button Content="Close" Width="78" Height="34" Click="Close_Click"
                        Style="{StaticResource PrimaryButtonStyle}" />
            </StackPanel>
        </Grid>
    </Grid>
</Window>
