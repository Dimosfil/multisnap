<Window x:Class="MultiSnap.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MultiSnap" Height="760" Width="1120" MinHeight="560" MinWidth="860"
        Background="{StaticResource AppBackgroundBrush}" WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="318" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Background="{StaticResource PanelBackgroundBrush}" Padding="22" BorderBrush="{StaticResource StrokeBrush}" BorderThickness="0,0,1,0">
            <DockPanel LastChildFill="True">
                <StackPanel DockPanel.Dock="Top" Margin="0,0,0,22">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,24">
                        <Border Width="48" Height="48" CornerRadius="10" Background="#10141C" Margin="0,0,14,0">
                            <Image Source="{StaticResource AppIconImage}" Width="48" Height="48" />
                        </Border>
                        <StackPanel>
                            <TextBlock Text="MultiSnap" Foreground="{StaticResource TextPrimaryBrush}" FontSize="25" FontWeight="SemiBold" />
                            <TextBlock Text="Capture, mark up, ship." Foreground="{StaticResource TextSecondaryBrush}" Margin="0,3,0,0" />
                        </StackPanel>
                    </StackPanel>

                    <Button Content="Capture Area" Height="44" Margin="0,0,0,10" Click="CaptureArea_Click" Style="{StaticResource PrimaryButtonStyle}" />
                    <Button Content="Full Screen" Height="44" Margin="0,0,0,24" Click="CaptureFull_Click" />

                    <TextBlock Text="Settings" Foreground="{StaticResource TextPrimaryBrush}" FontWeight="SemiBold" Margin="0,0,0,8" />
                    <Border BorderBrush="{StaticResource StrokeBrush}" Background="#1D2330" BorderThickness="1" CornerRadius="8" Padding="14" Margin="0,0,0,22">
                        <StackPanel>
                            <TextBlock Text="Area capture hotkey" Foreground="#CBD5E1" />
                            <TextBlock x:Name="AreaHotkeyText" Text="Ctrl+PrintScreen" Foreground="{StaticResource TextPrimaryBrush}" FontWeight="SemiBold" Margin="0,4,0,0" />
                            <Border Background="#10141C" CornerRadius="6" Padding="8,5" HorizontalAlignment="Left" Margin="0,9,0,0">
                                <TextBlock x:Name="HotkeyStatusText" Text="Checking..." Foreground="{StaticResource AccentWarmBrush}" FontWeight="SemiBold" />
                            </Border>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <StackPanel DockPanel.Dock="Bottom">
                    <TextBlock x:Name="ClipboardStatusText" Text="Captured images are copied to clipboard immediately." Foreground="{StaticResource TextSecondaryBrush}"
                               TextWrapping="Wrap" />
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid Grid.Column="1" Background="{StaticResource AppBackgroundBrush}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <ToolBarTray Background="#121722">
                <ToolBar Background="#121722" Foreground="{StaticResource TextPrimaryBrush}">
                    <Button Content="Copy" Click="Copy_Click" />
                    <Button Content="Save PNG" Click="Save_Click" />
                    <Separator />
                    <Button Content="Clear Ink" Click="ClearInk_Click" />
                </ToolBar>
            </ToolBarTray>

            <Border Grid.Row="1" Margin="22" Background="{StaticResource SurfaceBackgroundBrush}" BorderBrush="{StaticResource StrokeBrush}" BorderThickness="1" CornerRadius="8">
                <Grid x:Name="EditorSurface" ClipToBounds="True">
                    <StackPanel x:Name="EmptyState" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Image Source="{StaticResource AppIconImage}" Width="74" Height="74" Opacity="0.95" Margin="0,0,0,18" />
                        <TextBlock Text="Ready to capture" Foreground="{StaticResource TextPrimaryBrush}"
                                   FontSize="30" FontWeight="SemiBold" HorizontalAlignment="Center" />
                        <TextBlock Text="Use the tray hotkey or capture buttons to start." Foreground="{StaticResource TextSecondaryBrush}"
                                   Margin="0,8,0,0" HorizontalAlignment="Center" />
                    </StackPanel>
                    <Image x:Name="CaptureImage" Stretch="Uniform" />
                    <InkCanvas x:Name="InkLayer" Background="Transparent" EditingMode="Ink" />
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
