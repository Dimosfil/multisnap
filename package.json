{
  "name": "multisnap",
  "version": "0.1.2",
  "description": "Fast screenshot capture and annotation desktop app.",
  "main": "dist/main/main.js",
  "type": "module",
  "scripts": {
    "dev": "tsc -p tsconfig.node.json && concurrently -k \"vite --host 127.0.0.1 --port 5187\" \"wait-on http://127.0.0.1:5187 && electron .\"",
    "build": "tsc -p tsconfig.node.json && vite build",
    "check": "tsc --noEmit && tsc -p tsconfig.node.json --noEmit",
    "preview": "vite preview --host 127.0.0.1"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.0.4",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.17",
    "@types/react-dom": "^18.3.5",
    "concurrently": "^9.1.0",
    "electron": "^33.2.1",
    "typescript": "^5.7.2",
    "vite": "^6.0.5",
    "wait-on": "^8.0.1"
  }
}
